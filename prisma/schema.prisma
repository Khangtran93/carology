// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id    String  @id @default(uuid())
  email String  @unique
  emailVerified DateTime?
  password String?
  name  String?
  image String?
  accounts Account[]
  sessions Session[]
  complaints Complaint[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Brand {
  id String @id @default(uuid()) 
  name String @unique
  brandModels BrandModel[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  slug String @unique
}

model BrandModel {
  id String @id @default(uuid())
  name String
  brandId String
  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  carModels CarModel[]
  carType CarType?
  specs Specs?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  slug String

  @@unique([brandId, slug])
  @@index([carType])
}
model CarModel {
  id String @id @default(uuid())
  name String
  year Int?
  brandModelId String 
  brandModel BrandModel @relation(fields: [brandModelId], references: [id], onDelete: Cascade)
  complaints Complaint[]
  images ModelImage[]
  trims Trim[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  slug String

  @@unique([brandModelId, slug])
  @@index([brandModelId])
}

model Complaint {
  id String @id @default(uuid())
  title String
  content String
  userId String
  user User @relation(fields: [userId], references: [id])
  carModelId String
  carModel CarModel @relation(fields: [carModelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carModelId])
  @@index([userId])
}

model Trim {
  id String @id @default(uuid())
  name String
  carModelId String
  carModel CarModel @relation(fields: [carModelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carModelId])
}

model ModelImage {
  id String @id @default(uuid())
  url String
  alt String
  isPrimary Boolean

    // Attribution (required for CC-BY-SA compliance)
  photographer  String?
  license       String?
  sourceUrl     String?  // link back to Wikimedia page
  
  carModelId String
  carModel CarModel @relation(fields: [carModelId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carModelId])
}

model Specs {
  id            String   @id @default(uuid())
  brandModelId    String   @unique
  brandModel      BrandModel @relation(fields: [brandModelId], references: [id], onDelete: Cascade)
  
  // Engine
  engineSize    Float?   // litres, e.g., 2.0
  power         Int?     // kW
  torque        Int?     // Nm
  
  // Fuel
  fuelType      FuelType?
  fuelEconomy   Float?   // L/100km combined
  
  // Drivetrain
  transmission  String? 
  drivetrain    Drivetrain?
  
  seats         Int?
  bootCapacity  Int?    
  
  startingPrice Int?     // AUD before on-roads
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  PHEV
  ELECTRIC
}

enum Drivetrain {
  FWD
  RWD
  AWD
  FOUR_WD  // "4WD" can't start with a number in Prisma enums
}
enum CarType {
  SEDAN
  COUPE
  HATCHBACK
  SUV
  UTE
  VAN
  PEOPLE_MOVER
  CONVERTIBLE
  WAGON
}
